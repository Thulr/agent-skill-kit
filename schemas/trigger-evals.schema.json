{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Thulr/informed-skills/blob/main/schemas/trigger-evals.schema.json",
  "title": "Trigger evals (evals/trigger-evals.json)",
  "description": "Canonical shape for every skill's evals/trigger-evals.json. Per-skill scripts assert the 'skill' field matches the skill name via jq after schema validation passes.",
  "type": "object",
  "required": ["skill", "version", "queries"],
  "additionalProperties": true,
  "properties": {
    "skill": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["query", "should_activate"],
        "additionalProperties": true,
        "properties": {
          "query": {"type": "string", "minLength": 1},
          "should_activate": {"type": "boolean"},
          "expected_route": {"type": ["string", "null"]},
          "category": {
            "type": ["string", "null"],
            "enum": ["positive", "negative", "edge", null]
          }
        }
      }
    }
  }
}
