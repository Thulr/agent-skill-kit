{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Thulr/agent-skill-kit/blob/main/schemas/trigger-evals.schema.json",
  "title": "Trigger evals (evals/trigger-evals.json)",
  "description": "Canonical shape for every skill's evals/trigger-evals.json. Per-skill scripts assert the 'skill' field matches the skill name via jq after schema validation passes.",
  "type": "object",
  "required": ["skill", "version", "queries"],
  "additionalProperties": true,
  "properties": {
    "skill": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["query", "should_activate", "expected_route", "category"],
        "additionalProperties": true,
        "properties": {
          "query": {"type": "string", "minLength": 1},
          "should_activate": {"type": "boolean"},
          "expected_route": {
            "type": ["string", "null"],
            "pattern": "^[a-z0-9][a-z0-9._/-]*$"
          },
          "category": {
            "type": "string",
            "enum": ["positive", "negative", "edge"]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "should_activate": {"const": false}
              },
              "required": ["should_activate"]
            },
            "then": {
              "properties": {
                "expected_route": {"type": "null"}
              }
            }
          }
        ]
      }
    }
  }
}
