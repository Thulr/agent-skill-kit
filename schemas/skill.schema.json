{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Thulr/informed-skills/blob/main/schemas/skill.schema.json",
  "title": "Skill manifest (skill.json)",
  "description": "Canonical shape for skills/<name>/skill.json and the reserved skills/.experimental/<name>/skill.json lane. Per-skill scripts assert name match via jq after schema validation passes.",
  "type": "object",
  "required": ["name", "description", "version", "license", "status", "maintainers", "inspired_by"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["draft", "reviewed", "published"]
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^@[A-Za-z0-9-]+(?:/[A-Za-z0-9-]+)?$"
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "inspired_by": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "author", "kind", "contribution"],
        "additionalProperties": true,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "author": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "year": {"type": ["integer", "null"]},
          "contribution": {"type": "string", "minLength": 1},
          "playbooks": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
